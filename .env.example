# 복사 후 .env.local 로 저장해 사용하세요. 실제 값은 GitHub·Vercel에 커밋하지 마세요.
# Vercel: Project → Settings → Environment Variables 에 동일 이름으로 등록

# 챗봇 자연어 (Gemini) — 없으면 온라인에서 FAQ 폴백만 동작
GEMINI_API_KEY=
# 선택. 비우면 gemini-2.0-flash
# GEMINI_CHAT_MODEL=gemini-2.0-flash

# 챗봇 레이트리밋 (Upstash Redis). 없으면 in-memory 폴백
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
